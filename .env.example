# ==============================================================================
# kloop configuration
# ------------------------------------------------------------------------------
# Copy this file to `.env` and adjust. Every variable is documented inline.
# Everything is 12-factor env-driven; there is no other config file.
# ==============================================================================

# ------------------------------------------------------------------------------
# Instance
# ------------------------------------------------------------------------------
# Public URL your users will reach kloop at (used in emails, discovery doc, QR).
PUBLIC_URL=http://localhost:8787

# Port the API/web server listens on inside the container / on the host.
PORT=8787

# Secret used to sign sessions & tokens. MUST be changed in production.
# Generate one with: openssl rand -hex 32
APP_SECRET=change-me-please-32-bytes-minimum!!

# node environment: development | production | test
NODE_ENV=development

# ------------------------------------------------------------------------------
# Database — the ONE hard dependency: PostgreSQL >= 15 with pgvector
# ------------------------------------------------------------------------------
# Bundled compose Postgres (default):
DATABASE_URL=postgres://kloop:kloop@localhost:5433/kloop
# Supabase example:
#   DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Neon / RDS / Cloud SQL: any Postgres connection string works.
# pgvector availability is verified on boot (`kloop doctor` checks it too).

# ------------------------------------------------------------------------------
# Object storage — photos, screenshots, voice memos
# ------------------------------------------------------------------------------
# Driver: local | s3   (s3 covers MinIO, AWS S3, Supabase Storage — anything S3-compatible)
STORAGE_DRIVER=local

# For STORAGE_DRIVER=local: directory attachments are written to.
STORAGE_LOCAL_PATH=./data/storage

# For STORAGE_DRIVER=s3:
#STORAGE_S3_ENDPOINT=http://localhost:9000     # omit for AWS S3
#STORAGE_S3_REGION=us-east-1
#STORAGE_S3_BUCKET=kloop
#STORAGE_S3_ACCESS_KEY=minioadmin
#STORAGE_S3_SECRET_KEY=minioadmin
#STORAGE_S3_FORCE_PATH_STYLE=true              # true for MinIO

# ------------------------------------------------------------------------------
# LLM provider — drafts articles, merge proposals, reply drafts, structuring
# ------------------------------------------------------------------------------
# Provider: openai | anthropic | ollama | mock
# `mock` is deterministic and needs no API key — the whole product runs without
# external AI (suggestions/drafts are template-based instead of LLM-written).
LLM_PROVIDER=mock

# openai
#OPENAI_API_KEY=sk-...
#OPENAI_MODEL=gpt-4o-mini
#OPENAI_BASE_URL=https://api.openai.com/v1     # override for compatible gateways

# anthropic
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-sonnet-4-5

# ollama (fully local)
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=llama3.1

# ------------------------------------------------------------------------------
# Embedding provider — powers matching, clustering, dedup, gap detection
# ------------------------------------------------------------------------------
# Provider: gemini | openai | ollama | mock
# Default (recommended): gemini `gemini-embedding-2` — natively multimodal, so
# photos and voice notes embed into the same vector space as text.
EMBEDDING_PROVIDER=mock

# Vector dimension stored in Postgres. Providers that support flexible output
# (gemini-embedding-2, text-embedding-3-*) are asked for exactly this size;
# fixed-size models are truncated/padded + re-normalized to fit.
# NOTE: changing this after install requires re-embedding (see docs).
EMBEDDING_DIMENSIONS=1536

# gemini
#GEMINI_API_KEY=...
#GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# openai embeddings
#OPENAI_API_KEY=sk-...                          # shared with LLM section
#OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ollama embeddings
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ------------------------------------------------------------------------------
# Automation
# ------------------------------------------------------------------------------
# Default automation tier for new orgs (0-3). Orgs can change it in settings,
# globally and per tag.
#   0 = suggestions only
#   1 = AI drafts replies, supporter sends
#   2 = auto-answer high-confidence recurring issues, escalate on "didn't help"
#   3 = auto-answer + auto-close on user confirmation
AUTOMATION_TIER=0

# ------------------------------------------------------------------------------
# Email (outbound: magic links, notifications. Inbound: see EMAIL_IN below)
# ------------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
#SMTP_USER=
#SMTP_PASS=
MAIL_FROM="kloop <kloop@localhost>"

# Inbound email intake: POST parsed emails to /api/intake/email
# (SendGrid Inbound Parse / Mailgun routes / SES-SNS compatible payloads).
# Requests created via email get channel=email. Secret guards the endpoint:
#EMAIL_IN_SECRET=

# ------------------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------------------
# Log level: debug | info | warn | error
LOG_LEVEL=info

# Seed demo data on boot when the database is empty (great for evaluation).
SEED_DEMO=false
