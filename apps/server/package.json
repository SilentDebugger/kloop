{
  "name": "@kloop/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "kloop": "tsx src/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/cli.ts migrate",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@hono/node-server": "^2.0.8",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "nodemailer": "^9.0.3",
    "openid-client": "^6.8.4",
    "pg": "^8.22.0",
    "pg-boss": "^12.25.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
